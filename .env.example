# Supabase (public — safe to expose in client bundles)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# App URL — used for invite email redirectTo (no trailing slash)
# local: http://localhost:3000  |  production: https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Supabase service role — server-only, NEVER expose to client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic — server-only
ANTHROPIC_API_KEY=sk-ant-...

# Worker secret — required for /api/analysis-worker/process
# Generate with: openssl rand -hex 32
WORKER_SECRET=your-random-secret

# AssemblyAI — server-only, required for audio transcription
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here
